# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database - MongoDB (Docker)
MONGODB_URI=mongodb://admin:password@mongodb:27017/gupshup?authSource=admin

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# AWS S3 (for file uploads) - Optional
AWS_ACCESS_KEY_ID=optional_aws_key
AWS_SECRET_ACCESS_KEY=optional_aws_secret
AWS_S3_BUCKET=optional_bucket_name
AWS_REGION=us-east-1
